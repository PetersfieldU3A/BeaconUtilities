{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deps: Sync From pyproject",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke deps",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Playwright: Record Beacon Actions",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke playwright-record",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Docs: Serve (MkDocs)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke docs",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Version: Bump Minor",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke bump --part=minor",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Version: Bump Patch",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke bump --part=patch",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Build: Python Package",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Package: Installer Zip",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke package",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Release: Build + Installer Zip",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build: Python Package",
        "Package: Installer Zip"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "CI: Local Check",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m invoke ci",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    }
  ]
}
